# ShikshaSignal AI — environment template. Copy to `.env` and fill as needed.
# Milestone 1 + 3 (deterministic core + MockLLM compiler) need NONE of these:
# the default LLM_PROVIDER=mock runs fully offline with no API keys.
# Milestone 4 (free/local providers) only activates when LLM_PROVIDER is set to
# gemini / groq / ollama AND the matching credentials are present.

# ---- LLM provider selector ----------------------------------------------------
# mock     — offline Jinja templates (default, no keys required)
# gemini   — Google Generative Language REST (free tier, key required)
# groq     — Groq Cloud OpenAI-compatible endpoint (free tier, key required)
# ollama   — local Ollama server (no key, requires the daemon to be running)
LLM_PROVIDER=mock

# ---- Gemini ------------------------------------------------------------------
# Either of these is accepted; GOOGLE_API_KEY wins if both are set.
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---- Groq --------------------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ---- Ollama (local) ----------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ---- Synthetic data generation -----------------------------------------------
DATA_SEED=42

# ---- App ---------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
