# ShikshaSignal AI — environment template. Copy to `.env` and fill as needed.
# Phase 1 (deterministic core) needs NONE of these — the default provider is `mock`,
# which runs fully offline with no API keys. Real providers are wired in Phase 3.

# LLM provider: mock | gemini | groq | ollama   (default = mock; never a paid API)
LLM_PROVIDER=mock

# Free-tier keys (only needed if you switch LLM_PROVIDER away from mock)
GEMINI_API_KEY=
GROQ_API_KEY=

# Model names are read from env so deprecations/renames don't break the code.
GEMINI_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_MODEL=qwen2.5:7b

# Synthetic data generation
DATA_SEED=42

APP_ENV=development
LOG_LEVEL=INFO
